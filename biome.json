{
	"$schema": "https://biomejs.dev/schemas/2.1.2/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineEnding": "lf",
		"lineWidth": 100
	},
 "assist": {
      "actions": {
         "source": {
            "organizeImports": "on",
            "useSortedAttributes": "on",
            "useSortedInterfaceMembers": "on",
            "useSortedProperties": "on"
         }
      }
   },
	"linter": {
		"enabled": false,
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"expand": "auto"
		}
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/pnpm-lock.yaml",
			"!**/package-lock.json",
			"!**/yarn.lock",
			"!**/bun.lock",
			"!**/routeTree.gen.ts",
			"!**/routeTree.gen.ts",
			"!**/drizzle/",
			"!**/.drizzle/",
			"!**/.vercel/",
			"!**/.output/",
			"!**/.vinxi/",
			"!**/.wrangler/",
			"!**/.netlify/",
			"!**/dist/",
			"!**/node_modules/"
		]
	}
}
